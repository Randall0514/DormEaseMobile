<?xml version="1.0" encoding="utf-8"?>
<!-- File path: app/src/main/res/layout/item_notification_terminated.xml -->
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    android:layout_marginBottom="9dp"
    app:cardBackgroundColor="#EEF4FD">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="14dp">

        <!-- Red dot indicator -->
        <View
            android:id="@+id/unreadDot"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:background="@drawable/dot_red"
            android:layout_marginTop="5dp"
            android:layout_marginEnd="10dp"/>

        <!-- Content -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- Title + time row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvTerminatedTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Tenancy Terminated"
                    android:textSize="15sp"
                    android:textColor="#000000"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tvTerminatedTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Just now"
                    android:textSize="11sp"
                    android:textColor="#7799CC"/>

            </LinearLayout>

            <!-- Message body -->
            <TextView
                android:id="@+id/tvTerminatedMessage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textColor="#555555"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="10dp"/>

            <!-- "Terminated by Owner" badge -->
            <TextView
                android:id="@+id/tvTerminatedBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✗ Terminated by Owner"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#D32F2F"
                android:background="@drawable/badge_rejected"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp"
                android:layout_marginBottom="12dp"/>

            <!-- VIEW + APPEAL buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2">

                <Button
                    android:id="@+id/btnTerminatedView"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:text="VIEW"
                    android:textSize="12sp"
                    android:textColor="#4A90D9"
                    android:textStyle="bold"
                    android:background="@drawable/btn_outline_blue"
                    android:stateListAnimator="@null"/>

                <Button
                    android:id="@+id/btnTerminatedAppeal"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:text="APPEAL"
                    android:textSize="12sp"
                    android:textColor="@android:color/white"
                    android:textStyle="bold"
                    android:background="@drawable/btn_filled_blue"
                    android:stateListAnimator="@null"/>

            </LinearLayout>

        </LinearLayout>
    </LinearLayout>

</androidx.cardview.widget.CardView>
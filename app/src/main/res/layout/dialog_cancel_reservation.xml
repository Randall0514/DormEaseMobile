<?xml version="1.0" encoding="utf-8"?>
<!-- File path: app/src/main/res/layout/dialog_cancel_reservation.xml -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/dialog_bg">

    <!-- Colored header band -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/dialog_header_red"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="24dp"
        android:paddingBottom="20dp"
        android:gravity="center_horizontal">

        <!-- Icon circle -->
        <FrameLayout
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@drawable/circle_red_light"
            android:layout_marginBottom="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="✕"
                android:textSize="22sp"
                android:textColor="#D32F2F"
                android:textStyle="bold"/>
        </FrameLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cancel Reservation"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#1A1A2E"
            android:layout_marginBottom="6dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="This action cannot be undone."
            android:textSize="12sp"
            android:textColor="#888888"
            android:gravity="center"/>

    </LinearLayout>

    <!-- Body -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="20dp"
        android:paddingBottom="8dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Reason for cancellation"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#555577"
            android:letterSpacing="0.08"
            android:layout_marginBottom="8dp"/>

        <!-- Styled EditText container -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/input_bg_outlined"
            android:layout_marginBottom="6dp">

            <EditText
                android:id="@+id/etCancelReason"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="96dp"
                android:hint="Tell us why you're cancelling…"
                android:textColor="#1A1A2E"
                android:textSize="14sp"
                android:inputType="textMultiLine|textCapSentences"
                android:minLines="3"
                android:maxLines="5"
                android:gravity="top|start"
                android:padding="14dp"
                android:background="@null"/>
        </FrameLayout>

        <TextView
            android:id="@+id/tvCancelError"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Please enter a reason to continue."
            android:textSize="11sp"
            android:textColor="#D32F2F"
            android:visibility="gone"
            android:layout_marginBottom="4dp"/>

    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#F0F0F5"
        android:layout_marginTop="8dp"/>

    <!-- Buttons row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="20dp"
        android:weightSum="2">

        <Button
            android:id="@+id/btnCancelDialogBack"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="Go Back"
            android:textSize="13sp"
            android:textColor="#4A90D9"
            android:textStyle="bold"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:maxLines="1"
            android:background="@drawable/btn_outline_blue"
            android:stateListAnimator="@null"/>

        <Button
            android:id="@+id/btnCancelDialogSubmit"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="Cancel Booking"
            android:textSize="13sp"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:maxLines="1"
            android:background="@drawable/btn_filled_red"
            android:stateListAnimator="@null"/>

    </LinearLayout>

</LinearLayout>
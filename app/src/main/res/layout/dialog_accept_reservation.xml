<?xml version="1.0" encoding="utf-8"?>
<!-- File path: app/src/main/res/layout/dialog_accept_reservation.xml -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/dialog_bg"
    android:paddingStart="0dp"
    android:paddingEnd="0dp"
    android:paddingTop="0dp"
    android:paddingBottom="0dp">

    <!-- Colored header band -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/dialog_header_blue"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="24dp"
        android:paddingBottom="20dp"
        android:gravity="center_horizontal">

        <!-- Icon circle -->
        <FrameLayout
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@drawable/circle_blue_light"
            android:layout_marginBottom="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="✓"
                android:textSize="22sp"
                android:textColor="#1565C0"
                android:textStyle="bold"/>
        </FrameLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Confirm Acceptance"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#1A1A2E"
            android:layout_marginBottom="6dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="You're about to confirm this reservation."
            android:textSize="12sp"
            android:textColor="#888888"
            android:gravity="center"/>

    </LinearLayout>

    <!-- Info card body -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="20dp"
        android:paddingBottom="8dp">

        <!-- Info box -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/info_box_bg"
            android:padding="16dp"
            android:layout_marginBottom="14dp">

            <!-- Dorm row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="10dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Unit / Property"
                    android:textSize="12sp"
                    android:textColor="#7799CC"
                    android:textStyle="bold"/>
                <TextView
                    android:id="@+id/tvAcceptDormName"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="—"
                    android:textSize="12sp"
                    android:textColor="#1A1A2E"
                    android:textStyle="bold"
                    android:gravity="end"/>
            </LinearLayout>

            <!-- Move-in row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="10dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Move-in Date"
                    android:textSize="12sp"
                    android:textColor="#7799CC"
                    android:textStyle="bold"/>
                <TextView
                    android:id="@+id/tvAcceptMoveIn"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="—"
                    android:textSize="12sp"
                    android:textColor="#1A1A2E"
                    android:textStyle="bold"
                    android:gravity="end"/>
            </LinearLayout>

            <!-- Divider inside box -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E8EDF5"
                android:layout_marginBottom="10dp"/>

            <!-- Total row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Total Amount"
                    android:textSize="13sp"
                    android:textColor="#1A1A2E"
                    android:textStyle="bold"/>
                <TextView
                    android:id="@+id/tvAcceptTotal"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="—"
                    android:textSize="14sp"
                    android:textColor="#1565C0"
                    android:textStyle="bold"
                    android:gravity="end"/>
            </LinearLayout>

        </LinearLayout>

        <!-- Note text -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="By accepting, you agree to the move-in terms set by the property owner."
            android:textSize="11sp"
            android:textColor="#AAAACC"
            android:gravity="center"
            android:layout_marginBottom="4dp"/>

    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#F0F0F5"
        android:layout_marginTop="8dp"/>

    <!-- Buttons row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="20dp"
        android:weightSum="2">

        <Button
            android:id="@+id/btnAcceptDialogCancel"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="Not Yet"
            android:textSize="13sp"
            android:textColor="#4A90D9"
            android:textStyle="bold"
            android:background="@drawable/btn_outline_blue"
            android:stateListAnimator="@null"/>

        <Button
            android:id="@+id/btnAcceptDialogConfirm"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="Yes, Accept"
            android:textSize="13sp"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:background="@drawable/btn_filled_blue"
            android:stateListAnimator="@null"/>

    </LinearLayout>

</LinearLayout>
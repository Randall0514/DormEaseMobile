DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_db_password
DB_NAME=dormease_db
PORT=3000
DATABASE_URL=postgresql://postgres:your_db_password@localhost:5432/dormease_db

# Signup OTP settings
SIGNUP_OTP_TTL_MINUTES=10
SIGNUP_OTP_RESEND_SECONDS=60
SIGNUP_OTP_MAX_ATTEMPTS=5

# SMTP settings (required for OTP email)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@example.com
SMTP_PASS=your_smtp_app_password
SMTP_FROM="DormEase <your_email@example.com>"
